    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "dxf-writer": "^1.18.4",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "proj4": "^2.20.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
